{
  "_comment": "WSL/EnviDat MCP Server – Konfiguration für Claude Desktop",
  "_note": "Pfade müssen auf das tatsächliche Installationsverzeichnis angepasst werden.",
  "mcpServers": {
    "wsl-envidat": {
      "command": "uvx",
      "args": ["wsl-envidat-mcp"],
      "_alternative_pip": {
        "command": "python",
        "args": ["-m", "wsl_envidat_mcp.server"]
      },
      "_alternative_dev": {
        "command": "python",
        "args": ["-m", "wsl_envidat_mcp.server"],
        "env": {
          "PYTHONPATH": "/pfad/zu/wsl-envidat-mcp/src"
        }
      }
    }
  }
}
